# Runtime
LIVE_TRADING=false
LOG_LEVEL=INFO

# Bot identity (optional for report/reconciliation context)
BOT_WALLET_ADDRESS=

# Local dashboard server
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8765

# Manual approval via Telegram (optional but required if manual_confirmation_enabled=true)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# API hosts
POLYMARKET_DATA_API_HOST=https://data-api.polymarket.com
POLYMARKET_GAMMA_API_HOST=https://gamma-api.polymarket.com
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_CLOB_WS_HOST=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Live trading credentials (required only when LIVE_TRADING=true)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_CHAIN_ID=137
POLYMARKET_FUNDER=
POLYMARKET_SIGNATURE_TYPE=1
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
